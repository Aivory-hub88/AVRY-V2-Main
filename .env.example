# =============================================================================
# Aivory Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values.
#
#   cp .env.example .env
#   nano .env
#
# This single .env is read by all docker-compose files.
# NEVER commit .env to git.
# =============================================================================

# ─── TLS / Traefik (production only) ─────────────────────────────────────────
# Your email address for Let's Encrypt TLS certificates.
ACME_EMAIL=admin@aivory.id

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# From: Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-secret

# ─── Internal Service Auth ────────────────────────────────────────────────────
# Shared secret for service-to-service calls (VPS bridge → backend)
# Generate with: openssl rand -hex 32
INTERNAL_TOKEN=aivory-internal-2026

# ─── AI / OpenRouter ──────────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
DIAGNOSTIC_MODEL=qwen/qwen3-235b-a22b

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (use Supabase connection pooler for production)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Payments / Midtrans ──────────────────────────────────────────────────────
# Get keys at: https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-your-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-key

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ─── Composio (OAuth integrations) ───────────────────────────────────────────
# Get key at: https://app.composio.dev → Settings
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_REDIRECT_URL=https://dashboard.aivory.id/integrations/callback

# ─── n8n Workflow Automation ──────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin@aivory.local
N8N_BASIC_AUTH_PASSWORD=change-me-strong-password
# Generate after first n8n login: Settings → API → Create API Key
N8N_API_KEY=your-n8n-api-key-after-first-login
N8N_MCP_AUTH_TOKEN=aivory-mcp-token-2026
# Local:      http://localhost:5678/
# Production: https://n8n.aivory.id/
N8N_WEBHOOK_URL=https://n8n.aivory.id/

# ─── Careers Service ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-hex-char-encryption-key
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=careers@aivory.id
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=careers@aivory.id

# ─── Monitoring (Grafana) ─────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password
GF_SERVER_ROOT_URL=https://monitoring.aivory.id
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
CORS_ORIGINS=https://aivory.id,https://dashboard.aivory.id,https://admin.aivory.id,https://console.aivory.id
