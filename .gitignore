# =============================================================================
# Aivory Entry Repo — .gitignore
# =============================================================================

# ─── Secrets (never commit) ──────────────────────────────────────────────────
.env
.env.local
.env.production
*.pem
*.key
acme.json

# ─── Docker volumes / runtime data ───────────────────────────────────────────
vps-local/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
*.swp
*.swo

# ─── Node (shouldn't be in root but just in case) ────────────────────────────
node_modules/
