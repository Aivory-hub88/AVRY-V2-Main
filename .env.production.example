# ─── Aivory Platform — Production Environment ──────────────────────────────
# Copy to .env and fill in real values on the VPS.
# NEVER commit .env to git.

# ─── TLS / Traefik ───────────────────────────────────────────────────────────
ACME_EMAIL=admin@aivory.id

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your-strong-jwt-secret-min-32-chars

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/aivory

# ─── AI / OpenRouter ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key
DIAGNOSTIC_MODEL=qwen/qwen3-235b-a22b

# ─── Payments / Midtrans ─────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-your-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ─── Composio ────────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_REDIRECT_URL=https://dashboard.aivory.id/integrations/callback

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin@aivory.local
N8N_BASIC_AUTH_PASSWORD=your-strong-n8n-password
N8N_API_KEY=your-n8n-api-key
N8N_MCP_AUTH_TOKEN=your-mcp-auth-token
N8N_WEBHOOK_URL=https://n8n.aivory.id/

# ─── Internal service auth ───────────────────────────────────────────────────
INTERNAL_TOKEN=your-strong-internal-token-min-32-chars

# ─── Careers service ─────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-64-hex-char-encryption-key
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=careers@aivory.id
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=careers@aivory.id

# ─── Monitoring ──────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=your-grafana-password
GF_SERVER_ROOT_URL=https://monitoring.aivory.id
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
CORS_ORIGINS=https://aivory.id,https://dashboard.aivory.id,https://admin.aivory.id,https://console.aivory.id
